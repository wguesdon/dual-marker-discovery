# Copy this file to .env and fill in any values you need. The real .env is gitignored.
#
# The single-cell analysis needs NO key: CELLxGENE Census, Tabula Sapiens, HuPSA, and the Human
# Protein Atlas are all public. The variables below are only for the later phases.
#
# Anthropic API key, for the LLM-powered app phase (native Anthropic API, not OpenRouter).
# Obtain one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# AWS profile, only if scoring is offloaded to SageMaker rather than run locally.
AWS_PROFILE=
